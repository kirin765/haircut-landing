# Google Analytics ID (Measurement ID)
# Get this from Google Analytics 4 dashboard
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Add your environment variables here
RESEND_API_KEY=your_resend_api_key
CONTACT_EMAIL=support@reviewboost.co.kr
RESEND_FROM_EMAIL=No Show Hair <onboarding@resend.dev>

# Kakao JavaScript SDK App Key (for KakaoTalk share)
# Get this from https://developers.kakao.com (내 애플리케이션 > 앱 키 > JavaScript 키)
# If omitted, the KakaoTalk share button falls back to clipboard copy.
NEXT_PUBLIC_KAKAO_APP_KEY=
